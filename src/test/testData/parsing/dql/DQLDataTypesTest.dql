data record(
  long = 1233,
  double = 123.4567,
  scientific_notation = 99.123e-13,
  hex_number = 0x1A2B3C,
  negative_number = -9876e123,
  duration = 4min,
  string = "something",
  multiline_string = """
    something
    very
    long
  """,
  empty = null,
  boolean = true,
  time_align = @w2,
  negative_value_time_align = -2d@d
)
